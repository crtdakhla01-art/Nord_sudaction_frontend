# المجلدات الأساسية التي يجب تجاهلها
node_modules/
/dist
/build
/out

# ملفات السجلات (Logs)
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ملفات البيئة السرية (Environment Variables)
# هذه أهم نقطة لحماية مفاتيح الـ API الخاصة بك
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ملفات التعريف والاختبار (Testing & Coverage)
/coverage
/.nyc_output

# ملفات المحرر (Editors)
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ملفات TypeScript (إذا كنت تستخدمه)
*.tsbuildinfo

# ملفات النظام (System Files)
Thumbs.db
desktop.ini

# ملفات Vite أو أدوات البناء الأخرى
.vite/
.eslintcache